# ============================================================
# KASHTEC Construction Management System — .gitignore
# ============================================================

# ── Environment & Secrets (NEVER commit these) ───────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12
*.pfx

# ── Node.js ──────────────────────────────────────────────────
node_modules/
backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Uploaded / User-Generated Content ────────────────────────
uploads/
tmp/
temp/

# ── Test / Debug Files ────────────────────────────────────────
auth_test.json
get_token.json
token_response.json
test_*.json
test-image.*
test_workforce_request.js
*.test.local.*

# ── Dev / One-Off Scripts ────────────────────────────────────
add_*.py
fix_*.py
inject_*.py
append_*.py
patch_*.py
shrink_*.py
update_dept.py
*.backup
*.bak
diagnose-railway.*

# ── Large Binary / Backup Archives ───────────────────────────
*.zip
*.tar.gz
*.tar.bz2
*.7z
*.rar

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch

# ── Build Output ──────────────────────────────────────────────
dist/
build/
.cache/
.parcel-cache/

# ── Railway / Deployment Internal Docs ───────────────────────
RAILWAY-*.md
REDEPLOY.md
CHANGES_COMPLETED.md
ATTENDANCE_REAL_DATA_UPDATE.md
