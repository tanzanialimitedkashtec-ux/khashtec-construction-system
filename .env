# KASHTEC Construction Management System - Environment Variables

# Application Configuration
NODE_ENV=production
PORT=8080
APP_NAME=KASHTEC Construction Management System
APP_VERSION=1.0.0
APP_URL=https://your-app-name.railway.app

# Database Configuration (Railway)
DATABASE_URL=${MYSQL_PUBLIC_URL}
DB_HOST=${MYSQLHOST}
DB_USER=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}
DB_NAME=${MYSQLDATABASE}
DB_PORT=${MYSQLPORT}

# Security Configuration
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRE=7d
BCRYPT_ROUNDS=12
CORS_ORIGIN=${CORS_ORIGIN:-*}

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# GitHub Integration
GITHUB_TOKEN=${GITHUB_TOKEN}
GITHUB_REPO=${GITHUB_REPO}
GITHUB_BRANCH=${GITHUB_BRANCH:-main}
AUTO_PUSH_ENABLED=${AUTO_PUSH_ENABLED:-true}

# Notification Configuration
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT:-587}
SMTP_USER=${SMTP_USER}
SMTP_PASS=${SMTP_PASS}

# Railway Specific Variables
# These will be automatically set by Railway:
# - PORT
# - MYSQL_PUBLIC_URL
# - MYSQLHOST
# - MYSQLUSER
# - MYSQLPASSWORD
# - MYSQLDATABASE
# - MYSQLPORT

# Required Manual Setup:
# 1. JWT_SECRET - Generate a secure random string
# 2. GITHUB_TOKEN - GitHub personal access token
# 3. GITHUB_REPO - Your GitHub repository name
# 4. CORS_ORIGIN - Your application domain (for production)

# Optional Setup:
# 1. SMTP_* - Email notification settings
# 2. AUTO_PUSH_ENABLED - Enable/disable GitHub auto-push

# Generate JWT Secret:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
