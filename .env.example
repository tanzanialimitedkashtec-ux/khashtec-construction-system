# KASHTEC Construction Management System - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file with real credentials

# Environment
NODE_ENV=production

# Server Configuration
PORT=8080

# Database Configuration (set via Railway dashboard or your hosting provider)
DATABASE_URL=mysql://user:password@host:port/database
DB_HOST=your-database-host
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_NAME=your-database-name
DB_PORT=3306

# Security Configuration
JWT_SECRET=generate-a-strong-random-secret-here
BCRYPT_ROUNDS=12
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=https://your-production-domain.com

# Application Configuration
APP_NAME=KASHTEC Construction Management System
APP_VERSION=1.0.0
APP_URL=https://your-production-domain.com

# GitHub Token (if needed for integrations)
# GITHUB_TOKEN=your_github_token_here

# Email Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_RECIPIENT=your-notification-email@gmail.com

# Resend Email API (HTTPS-based, works on Railway where SMTP is blocked)
# Get a free key at https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=KASHTEC <onboarding@resend.dev>
